rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions (共用邏輯) ---

    // 檢查使用者是否已登入
    function isSignedIn() {
      return request.auth != null;
    }

    // 檢查使用者是否為該任務的成員
    function isMemberOfTask(taskId) {
      return isSignedIn() && (request.auth.uid in resource.data.memberIds);
    }

    // 檢查使用者是否為該任務的 Captain
    function isTaskCaptain(taskId) {
      return isSignedIn() && request.auth.uid == resource.data.captainId;
    }

    // 檢查使用者是否為該任務的成員 (跨路徑讀取父層)
    function isParentTaskMember(taskId) {
      return isSignedIn() &&
             (request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.memberIds);
    }

    // --- 規則定義 ---

    // [新增] 1. 系統全域設定 (Config)
    // S50/S72 需要讀取這裡的版本號來比對
    match /config/legal {
      allow read: if true;   // 允許公開讀取 (因為這是公開的版本資訊)
      allow write: if false; // 禁止 App 寫入 (只能由開發者在 Console 修改)
    }

    // 2. 使用者資料
    // S50 需要寫入 agreed_tos_version 到這裡
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 3. 任務資料 (Tasks)
    match /tasks/{taskId} {
      // [讀取]: 必須是成員
      allow read: if isMemberOfTask(taskId);

      // [更新]:
      // - 一般欄位：成員可更新
      // - captainId/status：只有 Captain 可更新
      allow update: if isMemberOfTask(taskId) &&
                    (
                      !request.resource.data.diff(resource.data).changedKeys().hasAny(["captainId", "status"]) ||
                      isTaskCaptain(taskId)
                    );

      // [刪除]: 只有 Captain 可刪除任務
      allow delete: if isTaskCaptain(taskId);

      // [建立]: 確保建立者在成員名單裡
      allow create: if isSignedIn() &&
                    (request.auth.uid in request.resource.data.memberIds);

      // 子集合: 記帳紀錄 (Records)
      match /records/{recordId} {
        allow read, write: if isParentTaskMember(taskId);
      }

      // 子集合: 活動日誌 (Activity Logs)
      match /activity_logs/{logId} {
        allow read, create: if isParentTaskMember(taskId);
        allow update, delete: if false;
      }
    }

    // 4. 拒絕其他所有未定義路徑 (安全性兜底)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
